#!/usr/bin/env bash
# ibmvm — Simple IBM Cloud VPC VM manager
set -euo pipefail
IFS=$'\n\t'

# ── Paths ─────────────────────────────────────────────────────────────────────
IBMVM_DIR="${HOME}/.ibmvm"
CONFIG_FILE="${IBMVM_DIR}/config"
# ── Defaults (populated from config after first setup) ────────────────────────
REGION=""
PROFILE="bx2-2x8"
IMAGE="ibm-ubuntu-24-04"
SSH_USER="ubuntu"
SSH_KEY_FILE="${HOME}/.ssh/id_rsa"
ZONE=""
SETUP_DONE_REGION=""
RG_NAME="ibmvm"
VPC_NAME="ibmvm-vpc"
SUBNET_NAME="ibmvm-subnet"
KEY_NAME="ibmvm-key"
VM_PREFIX="ibmvm-"
ACCESS_SG_NAME="ibmvm-access"

# ── Colors ────────────────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
  C_RED=$'\033[0;31m' C_GRN=$'\033[0;32m' C_YEL=$'\033[1;33m'
  C_BLU=$'\033[0;34m' C_BOLD=$'\033[1m'   C_DIM=$'\033[2m' C_RST=$'\033[0m'
else
  C_RED='' C_GRN='' C_YEL='' C_BLU='' C_BOLD='' C_DIM='' C_RST=''
fi

log_info() { echo -e "${C_BLU}→${C_RST} $*"; }
log_ok()   { echo -e "${C_GRN}✓${C_RST} $*"; }
log_warn() { echo -e "${C_YEL}⚠${C_RST} $*"; }
die()      { echo -e "${C_RED}✗${C_RST} $*" >&2; exit 1; }

# Run a command in the background showing dots until it finishes.
# Captures stdout into the named variable; stderr is discarded.
# Usage: _capturing varname "Label..." cmd [args...]
_capturing() {
  local _var="$1" _msg="$2"; shift 2
  local _tmp; _tmp=$(mktemp)
  printf '  %s' "$_msg"
  "$@" > "$_tmp" 2>/dev/null &
  local _pid=$!
  while kill -0 "$_pid" 2>/dev/null; do printf '.'; sleep 2; done
  wait "$_pid" || true
  printf '\n'
  printf -v "$_var" '%s' "$(cat "$_tmp")"
  rm -f "$_tmp"
}

confirm() {
  # Usage: confirm "message" → returns 0 (yes) or 1 (no)
  echo -en "${C_BOLD}?${C_RST} $* [y/N] "
  local reply; read -r reply
  [[ "$reply" =~ ^[Yy]$ ]]
}

confirm_yes() {
  # Like confirm but defaults to yes
  echo -en "${C_BOLD}?${C_RST} $* [Y/n] "
  local reply; read -r reply
  [[ -z "$reply" ]] || [[ "$reply" =~ ^[Yy]$ ]]
}

# ── Config ────────────────────────────────────────────────────────────────────
load_config() {
  mkdir -p "$IBMVM_DIR"
  local account_id
  account_id=$(_current_account_id 2>/dev/null || true)
  # Fallback: JWT absent or missing account claim (e.g. IBM Cloud Shell token format)
  if [[ -z "$account_id" ]]; then
    account_id=$(ibmcloud target --output JSON 2>/dev/null \
      | jq -r '.account.guid // empty' 2>/dev/null || true)
  fi
  if [[ -n "$account_id" ]]; then
    CONFIG_FILE="${IBMVM_DIR}/config.${account_id}"
  fi
  if [[ -f "$CONFIG_FILE" ]]; then source "$CONFIG_FILE"; fi
}

save_config() {
  mkdir -p "$IBMVM_DIR"
  cat > "$CONFIG_FILE" <<'CFGEOF'
# ibmvm configuration — managed by ibmvm setup
CFGEOF
  cat >> "$CONFIG_FILE" <<EOF
REGION="${REGION}"
PROFILE="${PROFILE}"
SSH_USER="${SSH_USER}"
SSH_KEY_FILE="${SSH_KEY_FILE}"
ZONE="${ZONE}"
IMAGE="${IMAGE}"
SETUP_DONE_REGION="${SETUP_DONE_REGION}"
RG_NAME="${RG_NAME}"
VPC_NAME="${VPC_NAME}"
SUBNET_NAME="${SUBNET_NAME}"
KEY_NAME="${KEY_NAME}"
EOF
  chmod 600 "$CONFIG_FILE"
}

# ── Pre-checks ────────────────────────────────────────────────────────────────
check_deps() {
  local missing=()
  command -v ibmcloud &>/dev/null || missing+=("ibmcloud")
  command -v jq       &>/dev/null || missing+=("jq")
  [[ ${#missing[@]} -eq 0 ]] || die "Missing required tools: ${missing[*]}"
}

_decode_iam_jwt() {
  # Return the decoded JWT payload from the ibmcloud config as JSON.
  # ibmcloud CLI stores config in ~/.bluemix (older) or ~/.ibmcloud (newer).
  local cfg="${HOME}/.bluemix/config.json"
  [[ -f "$cfg" ]] || cfg="${HOME}/.ibmcloud/config.json"
  [[ -f "$cfg" ]] || return 1
  local token
  token=$(jq -r '.IAMToken // empty' "$cfg" 2>/dev/null) || return 1
  [[ -n "$token" ]] || return 1
  local b64
  b64=$(printf '%s' "${token#Bearer }" | awk -F. '{print $2}' | tr '_-' '/+')
  # Pad to multiple of 4
  b64="${b64}$(printf '%0.s=' $(seq 1 $(( (4 - ${#b64} % 4) % 4 ))))"
  printf '%s' "$b64" | base64 -d 2>/dev/null
}

_iam_token_valid() {
  local payload exp now
  payload=$(_decode_iam_jwt) || return 1
  exp=$(printf '%s' "$payload" | jq -r '.exp // 0' 2>/dev/null) || return 1
  now=$(date +%s)
  [[ "${exp:-0}" -gt "$now" ]]
}

_current_account_id() {
  # Extract the IBM Cloud account GUID from the local JWT — no network call.
  # This is account.bss (the account's BSS GUID), NOT the IAM user/identity ID.
  local payload
  payload=$(_decode_iam_jwt) || return 1
  printf '%s' "$payload" | jq -r '.account.bss // empty' 2>/dev/null
}

_ensure_account_targeted() {
  # If no account is targeted yet, auto-select the user's primary account.
  local acc_id
  acc_id=$(_current_account_id 2>/dev/null || true)
  [[ -n "$acc_id" ]] && return

  acc_id=$(ibmcloud target --output JSON 2>/dev/null | jq -r '.account.guid // empty' || true)
  [[ -n "$acc_id" ]] && return

  local guid
  guid=$(ibmcloud account list --output JSON 2>/dev/null \
    | jq -r '[.[] | select(.state == "ACTIVE")] | .[0].guid // empty' 2>/dev/null || true)
  if [[ -n "$guid" ]]; then
    log_info "Targeting account ${guid}..."
    ibmcloud target -c "$guid" -q \
      || log_warn "Could not auto-target account — run: ibmcloud target -c <account-id>"
  fi
}

check_login() {
  # Fast path: valid local JWT with an account targeted — no network call needed
  if _iam_token_valid && [[ -n "$(_current_account_id 2>/dev/null || true)" ]]; then
    return
  fi

  # Slow path: token absent/expired or no account in JWT
  echo -n "  Checking IBM Cloud login..." >&2
  if ibmcloud account show -q &>/dev/null 2>&1; then
    echo "" >&2
    _ensure_account_targeted
    return
  fi
  echo "" >&2

  # Try IBMCLOUD_APIKEY auto-login
  if [[ -n "${IBMCLOUD_APIKEY:-}" ]]; then
    log_info "Logging in with IBMCLOUD_APIKEY..."
    ibmcloud login --apikey "$IBMCLOUD_APIKEY" -q \
      || die "Login with IBMCLOUD_APIKEY failed."
    _ensure_account_targeted
    return
  fi

  die "Not logged in to IBM Cloud. Run: ibmcloud login  (or set IBMCLOUD_APIKEY)"
}

ensure_region() {
  [[ -n "${REGION:-}" ]] || die "ibmvm is not configured. Run: ibmvm setup"
  local current
  current=$(ibmcloud target --output JSON 2>/dev/null | jq -r '.region.name // empty')
  if [[ "$current" != "$REGION" ]]; then
    ibmcloud target -r "$REGION" -q \
      || die "Failed to target region '${REGION}'"
  fi
}

get_zone() {
  [[ -n "$ZONE" ]] && echo "$ZONE" || echo "${REGION}-1"
}

# ── IBM Cloud helpers ─────────────────────────────────────────────────────────
# Wrapper: output JSON, suppress ibmcloud chatter, swallow errors (caller handles)
ic() { ibmcloud is "$@" --output JSON -q 2>/dev/null || true; }

# Look up a VPC resource ID by name via the plural list command (works across CLI versions).
# Usage: ic_id <list-subcommand> <name>   e.g. ic_id subnets ibmvm-subnet
ic_id() {
  ic "$1" | jq -r --arg n "$2" '.[] | select(.name == $n) | .id // empty' 2>/dev/null | head -1
}

# Get the caller's current public IP address.
my_ip() {
  local ip
  ip=$(curl -s --max-time 5 https://ifconfig.me 2>/dev/null) \
    || die "Could not determine public IP — check your network or specify an IP explicitly"
  [[ -n "$ip" ]] || die "Could not determine public IP"
  echo "$ip"
}

# Given a raw IP address, return the host CIDR (append /32 for IPv4, /128 for IPv6).
ip_to_cidr() {
  local ip="$1"
  # Strip any existing prefix length if caller passed one
  ip="${ip%%/*}"
  if [[ "$ip" == *:* ]]; then
    echo "${ip}/128"
  else
    echo "${ip}/32"
  fi
}

# Look up the access security group ID by name.
access_sg_id() {
  ic_id security-groups "$ACCESS_SG_NAME"
}

# Look up a floating IP ID by name.
fip_id() {
  ic floating-ips | jq -r --arg n "$1" '.[] | select(.name == $n) | .id // empty' 2>/dev/null | head -1
}

# Look up a floating IP address by name.
fip_address() {
  ic floating-ips | jq -r --arg n "$1" '.[] | select(.name == $n) | .address // empty' 2>/dev/null | head -1
}

# ── Setup / Prerequisites ─────────────────────────────────────────────────────
ensure_rg() {
  log_info "Resource group '${RG_NAME}'..."
  if ibmcloud resource group "$RG_NAME" -q &>/dev/null 2>&1; then
    log_ok "  exists"
  else
    log_info "  creating..."
    ibmcloud resource group-create "$RG_NAME" -q \
      || die "Failed to create resource group '${RG_NAME}'"
    log_ok "  created"
  fi
}

ensure_vpc() {
  log_info "VPC '${VPC_NAME}'..."
  local existing_id; existing_id=$(ic_id vpcs "$VPC_NAME")
  if [[ -n "$existing_id" ]]; then
    log_ok "  exists"
  else
    log_info "  creating..."
    ibmcloud is vpc-create "$VPC_NAME" \
      --resource-group-name "$RG_NAME" \
      --address-prefix-management auto \
      --output JSON -q > /dev/null \
      || die "Failed to create VPC '${VPC_NAME}'"
    log_ok "  created"
  fi
}

ensure_subnet() {
  local zone="$1"
  log_info "Subnet '${SUBNET_NAME}' (zone: ${zone})..."
  local existing_id; existing_id=$(ic_id subnets "$SUBNET_NAME")
  if [[ -n "$existing_id" ]]; then
    log_ok "  exists"
  else
    log_info "  creating..."
    ibmcloud is subnet-create "$SUBNET_NAME" "$VPC_NAME" \
      --zone "$zone" \
      --ipv4-address-count 256 \
      --resource-group-name "$RG_NAME" \
      --output JSON -q > /dev/null \
      || die "Failed to create subnet '${SUBNET_NAME}'"
    log_ok "  created"
  fi
}

ensure_ssh_key() {
  local pub_key_file="${SSH_KEY_FILE}.pub"
  [[ -f "$pub_key_file" ]] \
    || die "SSH public key not found: ${pub_key_file}\n  Generate one with: ssh-keygen -t ed25519"
  log_info "SSH key '${KEY_NAME}' in IBM Cloud..."
  local existing_id; existing_id=$(ic_id keys "$KEY_NAME")
  if [[ -n "$existing_id" ]]; then
    log_ok "  exists"
  else
    log_info "  uploading from ${pub_key_file}..."
    local key_type="rsa"
    [[ "$SSH_KEY_FILE" == *ed25519* ]] && key_type="ed25519"
    ibmcloud is key-create "$KEY_NAME" "@${pub_key_file}" \
      --key-type "$key_type" \
      --resource-group-name "$RG_NAME" \
      --output JSON -q > /dev/null \
      || die "Failed to upload SSH key"
    log_ok "  uploaded"
  fi
}

ensure_sg_access() {
  log_info "Access security group '${ACCESS_SG_NAME}'..."
  local existing_id; existing_id=$(access_sg_id)
  if [[ -n "$existing_id" ]]; then
    log_ok "  exists"
  else
    log_info "  creating..."
    ibmcloud is security-group-create "$ACCESS_SG_NAME" \
      --vpc "$VPC_NAME" \
      --resource-group-name "$RG_NAME" \
      --output JSON -q > /dev/null \
      || die "Failed to create access security group"
    log_ok "  created (no rules — use: ibmvm access allow)"
  fi
}

ask() {
  # ask "Label" "default" → prints prompt to stderr, echoes answer to stdout (default if blank)
  local label="$1" default="$2"
  echo -en "  ${C_BOLD}${label}${C_RST} [${C_DIM}${default}${C_RST}]: " >&2
  local reply; read -r reply
  echo "${reply:-$default}"
}

# Find the 0-based index of the first item matching $2 in a JSON array using jq field $3.
# Echoes the index or -1 if not found.
_json_index() {
  local json="$1" value="$2" field="$3"
  echo "$json" | jq -r --arg v "$value" \
    "to_entries | map(select(.value.${field} == \$v)) | .[0].key // -1"
}

pick_region() {
  local regions_json
  regions_json=$(ibmcloud regions --output JSON 2>/dev/null || echo '[]')

  local count; count=$(echo "$regions_json" | jq 'length')
  [[ "${count:-0}" -gt 0 ]] || die "No regions found."

  local current_region
  current_region=$(ibmcloud target --output JSON 2>/dev/null | jq -r '.region.name // empty')
  local saved_region="${REGION:-${current_region:-}}"

  local default_idx=1
  if [[ -n "$saved_region" ]]; then
    local idx; idx=$(_json_index "$regions_json" "$saved_region" "Name")
    [[ "$idx" -ge 0 ]] && default_idx=$(( idx + 1 ))
  fi

  echo -e "\n  ${C_BOLD}Available regions:${C_RST}" >&2
  local i=1
  while IFS= read -r name; do
    printf "    %2d) %s\n" "$i" "$name" >&2
    i=$(( i + 1 ))
  done < <(echo "$regions_json" | jq -r '.[].Name')

  local current_label="${current_region:+ (current: ${current_region})}"
  echo -en "\n  ${C_BOLD}Region${C_RST}${current_label} [${C_DIM}${default_idx}${C_RST}]: " >&2
  local reply; read -r reply
  local sel="${reply:-$default_idx}"

  [[ "$sel" =~ ^[0-9]+$ ]] && [[ "$sel" -ge 1 ]] && [[ "$sel" -le "$count" ]] \
    || die "Invalid region selection: ${sel}"

  echo "$regions_json" | jq -r ".[$(( sel - 1 ))].Name"
}

pick_resource_group() {
  local groups_json
  groups_json=$(ibmcloud resource groups --output JSON 2>/dev/null || echo '[]')

  local count; count=$(echo "$groups_json" | jq 'length')
  local create_idx=$(( count + 1 ))

  local default_idx="$create_idx"
  if [[ -n "${RG_NAME:-}" ]]; then
    local idx; idx=$(_json_index "$groups_json" "$RG_NAME" "name")
    [[ "$idx" -ge 0 ]] && default_idx=$(( idx + 1 ))
  fi
  [[ "$default_idx" -eq "$create_idx" ]] && [[ "$count" -gt 0 ]] && default_idx=1

  echo -e "\n  ${C_BOLD}Resource group:${C_RST}" >&2
  local i=1
  while IFS= read -r name; do
    printf "    %2d) %s\n" "$i" "$name" >&2
    i=$(( i + 1 ))
  done < <(echo "$groups_json" | jq -r '.[].name')
  printf "    %2d) %s\n" "$create_idx" "Create new…" >&2

  echo -en "\n  ${C_BOLD}Resource group${C_RST} [${C_DIM}${default_idx}${C_RST}]: " >&2
  local reply; read -r reply
  local sel="${reply:-$default_idx}"

  [[ "$sel" =~ ^[0-9]+$ ]] && [[ "$sel" -ge 1 ]] && [[ "$sel" -le "$create_idx" ]] \
    || die "Invalid resource group selection: ${sel}"

  if [[ "$sel" -eq "$create_idx" ]]; then
    local new_name
    new_name=$(ask "New resource group name" "${RG_NAME:-ibmvm}")
    echo "$new_name"
  else
    echo "$groups_json" | jq -r ".[$(( sel - 1 ))].name"
  fi
}

pick_subnet() {
  local vpc_name="$1"
  local rg_name="${2:-${vpc_name%-vpc}}"
  local subnets_json
  subnets_json=$(ibmcloud is subnets --vpc "$vpc_name" --output JSON -q 2>/dev/null || echo '[]')

  local count; count=$(echo "$subnets_json" | jq 'length')

  if [[ "${count:-0}" -eq 0 ]]; then
    echo "  (no subnets found — will create ${rg_name}-subnet)" >&2
    echo "${rg_name}-subnet"
    return
  fi

  local create_idx=$(( count + 1 ))

  local default_idx=1
  if [[ -n "${SUBNET_NAME:-}" ]]; then
    local idx; idx=$(_json_index "$subnets_json" "$SUBNET_NAME" "name")
    [[ "$idx" -ge 0 ]] && default_idx=$(( idx + 1 ))
  fi

  echo -e "\n  ${C_BOLD}Subnet:${C_RST}" >&2
  local i=1
  while IFS= read -r name; do
    printf "    %2d) %s\n" "$i" "$name" >&2
    i=$(( i + 1 ))
  done < <(echo "$subnets_json" | jq -r '.[].name')
  printf "    %2d) %s\n" "$create_idx" "Create new…" >&2

  echo -en "\n  ${C_BOLD}Subnet${C_RST} [${C_DIM}${default_idx}${C_RST}]: " >&2
  local reply; read -r reply
  local sel="${reply:-$default_idx}"

  [[ "$sel" =~ ^[0-9]+$ ]] && [[ "$sel" -ge 1 ]] && [[ "$sel" -le "$create_idx" ]] \
    || die "Invalid subnet selection: ${sel}"

  if [[ "$sel" -eq "$create_idx" ]]; then
    local new_name
    new_name=$(ask "New subnet name" "${SUBNET_NAME:-${rg_name}-subnet}")
    echo "$new_name"
  else
    echo "$subnets_json" | jq -r ".[$(( sel - 1 ))].name"
  fi
}

pick_ssh_key() {
  local cloud_json
  cloud_json=$(ic keys)

  local -a keys=()
  while IFS= read -r key_file; do
    [[ -f "${key_file}.pub" ]] && keys+=("$key_file")
  done < <(find "$HOME/.ssh" -maxdepth 1 -name 'id_*' ! -name '*.pub' -type f | sort)

  [[ "${#keys[@]}" -gt 0 ]] || die "No SSH private keys found in ~/.ssh/"

  local default_idx=1
  if [[ -n "${SSH_KEY_FILE:-}" ]]; then
    local i=1
    for k in "${keys[@]}"; do
      if [[ "$k" == "$SSH_KEY_FILE" ]]; then
        default_idx="$i"; break
      fi
      i=$(( i + 1 ))
    done
  fi

  echo -e "\n  ${C_BOLD}SSH keys:${C_RST}" >&2
  local i=1
  for key_file in "${keys[@]}"; do
    local fp; fp=$(ssh-keygen -lf "${key_file}.pub" 2>/dev/null | awk '{print $2}')
    local in_cloud; in_cloud=$(echo "$cloud_json" | jq --arg fp "$fp" \
      '[.[] | select(.fingerprint == $fp)] | length')
    local status_label="(will be uploaded)"
    [[ "${in_cloud:-0}" -gt 0 ]] && status_label="✓ in IBM Cloud"
    printf "    %2d) %s  %s\n" "$i" "$(basename "$key_file")" "$status_label" >&2
    i=$(( i + 1 ))
  done

  local count="${#keys[@]}"
  echo -en "\n  ${C_BOLD}SSH key${C_RST} [${C_DIM}${default_idx}${C_RST}]: " >&2
  local reply; read -r reply
  local sel="${reply:-$default_idx}"

  [[ "$sel" =~ ^[0-9]+$ ]] && [[ "$sel" -ge 1 ]] && [[ "$sel" -le "$count" ]] \
    || die "Invalid SSH key selection: ${sel}"

  echo "${keys[$(( sel - 1 ))]}"
}

cmd_setup() {
  check_deps
  check_login

  local _target
  _target=$(ibmcloud target --output JSON 2>/dev/null || echo '{}')
  local _account_id
  _account_id=$(printf '%s' "$_target" | jq -r '.account.guid // empty')
  if [[ -n "$_account_id" ]]; then
    CONFIG_FILE="${IBMVM_DIR}/config.${_account_id}"
    if [[ -f "$CONFIG_FILE" ]]; then source "$CONFIG_FILE"; fi
  fi
  local current_region
  current_region=$(printf '%s' "$_target" | jq -r '.region.name // empty')

  echo ""
  log_info "ibmvm setup — configure and validate infrastructure"
  echo ""

  local region="${REGION:-${current_region:-us-south}}"
  local rg_name="${RG_NAME:-ibmvm}"
  local vpc_name="${VPC_NAME:-${rg_name}-vpc}"
  local subnet_name="${SUBNET_NAME:-${rg_name}-subnet}"
  local profile="${PROFILE:-bx2-2x8}"
  local ssh_user="${SSH_USER:-ubuntu}"
  local image="${IMAGE:-}"

  # Discard saved SSH key if the key pair no longer exists on disk
  local ssh_key_file="${SSH_KEY_FILE:-}"
  if [[ -n "$ssh_key_file" ]] && ! { [[ -f "$ssh_key_file" ]] && [[ -f "${ssh_key_file}.pub" ]]; }; then
    ssh_key_file=""
  fi
  if [[ -z "$ssh_key_file" ]]; then
    # Prefer a key whose fingerprint is already registered in IBM Cloud
    local _cloud_fps
    _cloud_fps=$(ic keys | jq -r '.[].fingerprint' 2>/dev/null || true)
    if [[ -n "$_cloud_fps" ]]; then
      while IFS= read -r _kf; do
        [[ -f "${_kf}.pub" ]] || continue
        local _fp; _fp=$(ssh-keygen -lf "${_kf}.pub" 2>/dev/null | awk '{print $2}')
        [[ -z "$_fp" ]] && continue
        if printf '%s\n' "$_cloud_fps" | grep -qF "$_fp"; then
          ssh_key_file="$_kf"; break
        fi
      done < <(find "$HOME/.ssh" -maxdepth 1 -name 'id_*' ! -name '*.pub' -type f | sort)
    fi
    # Pick best local key by type preference
    if [[ -z "$ssh_key_file" ]]; then
      for _pref in id_ed25519 id_ecdsa id_rsa id_dsa; do
        if [[ -f "$HOME/.ssh/${_pref}" && -f "$HOME/.ssh/${_pref}.pub" ]]; then
          ssh_key_file="$HOME/.ssh/${_pref}"; break
        fi
      done
    fi
    # Fall back to any complete key pair
    if [[ -z "$ssh_key_file" ]]; then
      while IFS= read -r _kf; do
        [[ -f "${_kf}.pub" ]] && { ssh_key_file="$_kf"; break; }
      done < <(find "$HOME/.ssh" -maxdepth 1 -name 'id_*' ! -name '*.pub' -type f | sort)
    fi
    # Offer to generate if none found
    if [[ -z "$ssh_key_file" ]]; then
      log_warn "No SSH key pair found in ~/.ssh"
      if confirm_yes "Generate a new ed25519 key now?"; then
        ssh-keygen -t ed25519 -f "$HOME/.ssh/id_ed25519" -N "" \
          || die "ssh-keygen failed"
        ssh_key_file="$HOME/.ssh/id_ed25519"
      else
        die "An SSH key is required. Generate one with: ssh-keygen -t ed25519"
      fi
    fi
  fi

  # Resolve image name/pattern/ID → id + display name
  local _img_resolved; _img_resolved=$(resolve_image "${image:-ubuntu-24}")
  image=$(printf '%s' "$_img_resolved" | cut -f1)
  local image_label; image_label=$(printf '%s' "$_img_resolved" | cut -f2)

  local customize=false
  local prompt_label
  if [[ -n "${SETUP_DONE_REGION:-}" ]]; then
    log_info "Current configuration:"
    prompt_label="Keep these settings?"
  else
    log_info "Proposed configuration:"
    prompt_label="Use these settings?"
  fi

  echo ""
  printf "  ${C_BOLD}%-20s${C_RST} %s\n" "Region:"         "$region"
  printf "  ${C_BOLD}%-20s${C_RST} %s\n" "Resource group:" "$rg_name"
  printf "  ${C_BOLD}%-20s${C_RST} %s\n" "VPC:"            "$vpc_name"
  printf "  ${C_BOLD}%-20s${C_RST} %s\n" "Subnet:"         "$subnet_name"
  printf "  ${C_BOLD}%-20s${C_RST} %s\n" "SSH key:"        "$ssh_key_file"
  printf "  ${C_BOLD}%-20s${C_RST} %s\n" "Profile:"        "$profile"
  printf "  ${C_BOLD}%-20s${C_RST} %s\n" "SSH user:"       "$ssh_user"
  printf "  ${C_BOLD}%-20s${C_RST} %s\n" "Image:"          "$image_label"
  echo ""
  confirm_yes "$prompt_label" || customize=true
  echo ""

  if [[ "$customize" == true ]]; then
    region=$(pick_region)
    rg_name=$(pick_resource_group)
    vpc_name=$(ask "VPC name" "${vpc_name:-${rg_name}-vpc}")
    if [[ "$vpc_name" == "${rg_name}-vpc" ]]; then
      subnet_name=$(pick_subnet "$vpc_name" "$rg_name")
    else
      subnet_name=$(pick_subnet "$vpc_name")
    fi
    ssh_key_file=$(pick_ssh_key)
    profile=$(ask "Default profile" "$profile")
    if ! ibmcloud is instance-profile "$profile" --output JSON -q &>/dev/null 2>&1; then
      log_warn "Profile '${profile}' not found in IBM Cloud — check for a typo."
      confirm "Continue with this profile anyway?" \
        || { log_info "Aborted."; exit 1; }
    fi
    ssh_user=$(ask "Default SSH user" "$ssh_user")

    if [[ "$region" != "$current_region" ]]; then
      ibmcloud target -r "$region" -q \
        || die "Failed to target region '${region}'"
    fi

    image=$(pick_image)
  else
    if [[ "$region" != "$current_region" ]]; then
      ibmcloud target -r "$region" -q \
        || die "Failed to target region '${region}'"
    fi
  fi

  REGION="$region"
  RG_NAME="$rg_name"
  VPC_NAME="$vpc_name"
  SUBNET_NAME="$subnet_name"
  KEY_NAME="${rg_name}-key"
  SSH_KEY_FILE="$ssh_key_file"
  PROFILE="$profile"
  SSH_USER="$ssh_user"
  IMAGE="$image"
  ZONE="${region}-1"

  echo ""
  log_info "Validating infrastructure..."
  echo ""

  ensure_rg
  ensure_vpc
  ensure_subnet "$ZONE"
  ensure_ssh_key
  ensure_sg_access

  SETUP_DONE_REGION="$region"
  save_config

  echo ""
  log_ok "Setup complete. Config saved to ${CONFIG_FILE}"
  echo ""
}

ensure_prerequisites() {
  check_deps
  check_login
  [[ -n "${SETUP_DONE_REGION:-}" ]] \
    || die "ibmvm is not configured. Run: ibmvm setup"
  ensure_region
}

# ── Instance helpers ──────────────────────────────────────────────────────────
get_instance_json() {
  local out; out=$(ic instance "$1")
  echo "$out" | jq -e '.id' &>/dev/null && echo "$out" || echo ""
}

get_instance_status() {
  local data; data=$(get_instance_json "$1")
  [[ -n "$data" ]] && echo "$data" | jq -r '.status' || echo "not_found"
}

get_primary_nic_id() {
  local data; data=$(get_instance_json "$1")
  echo "$data" | jq -r '.primary_network_interface.id // empty'
}

get_floating_ip() {
  local nic_id; nic_id=$(get_primary_nic_id "$1")
  [[ -n "$nic_id" ]] || return 0
  ic instance-network-interface-floating-ips "$1" "$nic_id" \
    | jq -r '.[0].address // empty'
}

wait_for_status() {
  local name="$1" target="$2" timeout="${3:-180}"
  local elapsed=0
  echo -n "  Waiting for '${target}'"
  while [[ "$elapsed" -lt "$timeout" ]]; do
    local s; s=$(get_instance_status "$name")
    [[ "$s" == "$target" ]] && { echo " done"; return 0; }
    [[ "$s" == "failed" ]]  && { echo ""; die "Instance '${name}' entered failed state"; }
    echo -n "."; sleep 5; elapsed=$(( elapsed + 5 ))
  done
  echo ""
  die "Timed out waiting for '${name}' → '${target}'"
}

pick_image() {
  echo -e "\n  ${C_BOLD}Available images (public IBM-provided):${C_RST}" >&2

  local _raw
  _capturing _raw "Fetching images" \
    ibmcloud is images --visibility public --owner-type provider --output JSON -q
  local images_json
  images_json=$(printf '%s' "$_raw" | jq '[.[] | select(.status == "available")] | sort_by(.name) | reverse')

  local count; count=$(echo "$images_json" | jq 'length')
  [[ "${count:-0}" -gt 0 ]] || die "No available images found."

  local manual_idx=$(( count + 1 ))
  local default_idx=1
  if [[ -n "${IMAGE:-}" ]]; then
    local idx; idx=$(echo "$images_json" | jq --arg id "$IMAGE" \
      'to_entries | map(select(.value.id == $id)) | .[0].key // -1')
    [[ "$idx" -ge 0 ]] && default_idx=$(( idx + 1 )) || default_idx="$manual_idx"
  fi

  local i=1
  while IFS= read -r name; do
    printf "    %2d) %s\n" "$i" "$name" >&2
    i=$(( i + 1 ))
  done < <(echo "$images_json" | jq -r '.[].name')
  printf "    %2d) %s\n" "$manual_idx" "Enter image ID manually…" >&2

  echo -en "\n  ${C_BOLD}Image${C_RST} [${C_DIM}${default_idx}${C_RST}]: " >&2
  local reply; read -r reply
  local sel="${reply:-$default_idx}"

  if [[ "$sel" -eq "$manual_idx" ]]; then
    local custom_id
    custom_id=$(ask "Image ID" "${IMAGE:-}")
    [[ -n "$custom_id" ]] || die "No image ID provided."
    echo "$custom_id"
    return
  fi

  [[ "$sel" =~ ^[0-9]+$ ]] && [[ "$sel" -ge 1 ]] && [[ "$sel" -le "$count" ]] \
    || die "Invalid image selection: ${sel}"

  echo "$images_json" | jq -r ".[$(( sel - 1 ))].id"
}

# Resolve an image name/pattern/ID to an ID.
# Prints "<id> <name>" on stdout separated by a tab.
# Search order: exact ID → public IBM images by pattern → all images by pattern (catches private).
resolve_image() {
  local input="$1"

  # Already an ID
  if [[ "$input" =~ ^r[0-9]+-[0-9a-f-]+ ]]; then
    local name; name=$(ic image "$input" | jq -r '.name // empty' 2>/dev/null || true)
    printf '%s\t%s' "$input" "${name:-$input}"
    return
  fi

  # Pattern search — public IBM-provided images first (cheap, common case)
  local images_json
  _capturing images_json "Fetching images" \
    ibmcloud is images --visibility public --owner-type provider --output JSON -q
  local id name
  id=$(printf '%s' "$images_json" | jq -r --arg p "$input" \
    '[.[] | select(.status == "available" and (.name | contains($p)))] | sort_by(.name) | reverse | .[0].id // empty')
  name=$(printf '%s' "$images_json" | jq -r --arg p "$input" \
    '[.[] | select(.status == "available" and (.name | contains($p)))] | sort_by(.name) | reverse | .[0].name // empty')

  # Fall back to all images (catches private/custom)
  if [[ -z "$id" ]]; then
    _capturing images_json "Fetching private images" \
      ibmcloud is images --output JSON -q
    id=$(printf '%s' "$images_json" | jq -r --arg p "$input" \
      '[.[] | select(.status == "available" and (.name | contains($p)))] | sort_by(.name) | reverse | .[0].id // empty')
    name=$(printf '%s' "$images_json" | jq -r --arg p "$input" \
      '[.[] | select(.status == "available" and (.name | contains($p)))] | sort_by(.name) | reverse | .[0].name // empty')
  fi

  [[ -n "$id" ]] || die "No image found matching '${input}'"
  printf '%s\t%s' "$id" "${name:-$id}"
}

# List all ibmvm-managed instances (prefixed with VM_PREFIX) in the resource group.
list_ibmvm_instances() {
  local out
  out=$(ibmcloud is instances --resource-group-name "$RG_NAME" --output JSON -q 2>/dev/null || true)
  [[ -n "$out" ]] \
    && echo "$out" | jq --arg p "$VM_PREFIX" '[.[] | select(.name | startswith($p))]' \
    || echo '[]'
}

assign_floating_ip() {
  local name="$1"
  local fip_name="${name}-fip"

  # Reuse existing floating IP if already assigned to this instance
  local existing; existing=$(fip_address "$fip_name")
  if [[ -n "$existing" ]]; then
    echo "$existing"; return
  fi

  local nic_id; nic_id=$(get_primary_nic_id "$name")
  [[ -n "$nic_id" ]] || die "Could not find primary NIC for '${name}'"

  local fip_json
  fip_json=$(ibmcloud is floating-ip-reserve "$fip_name" \
    --nic "$nic_id" --in "$name" \
    --resource-group-name "$RG_NAME" \
    --output JSON -q) \
    || die "Failed to reserve floating IP"
  echo "$fip_json" | jq -r '.address'
}

# ── Access command ────────────────────────────────────────────────────────────

cmd_access() {
  local subcmd="${1:-list}"; shift || true

  local sg_id; sg_id=$(access_sg_id)
  [[ -n "$sg_id" ]] || die "Access security group '${ACCESS_SG_NAME}' not found. Run: ibmvm setup"

  case "$subcmd" in
    list)
      local rules; rules=$(ic security-group-rules "$sg_id")
      local count; count=$(echo "$rules" | jq '[.[] | select(.direction == "inbound" and .protocol == "tcp")] | length')
      if [[ "${count:-0}" -eq 0 ]]; then
        log_info "No IPs allowed. Use: ibmvm access allow"
        return
      fi
      local my_cidr=""
      local pub_ip; pub_ip=$(my_ip 2>/dev/null || true)
      [[ -n "$pub_ip" ]] && my_cidr=$(ip_to_cidr "$pub_ip")

      printf "${C_BOLD}%s${C_RST}\n" "IP"
      printf "${C_DIM}%s${C_RST}\n" "--"
      while IFS= read -r rule; do
        local cidr display_ip
        cidr=$(echo "$rule" | jq -r '.remote.cidr_block // .remote.address // "?"')
        display_ip="${cidr%/32}"; display_ip="${display_ip%/128}"
        if [[ "$cidr" == "$my_cidr" ]]; then
          printf "%s  ${C_GRN}← you${C_RST}\n" "$display_ip"
        else
          echo "$display_ip"
        fi
      done < <(echo "$rules" | jq -c '.[] | select(.direction == "inbound" and .protocol == "tcp")')
      ;;

    allow)
      local ip="${1:-}" note="${2:-}"
      [[ -n "$ip" ]] || { log_info "Detecting public IP..."; ip=$(my_ip); }
      local cidr; cidr=$(ip_to_cidr "$ip")

      # Skip if rule already exists
      local existing
      existing=$(ic security-group-rules "$sg_id" \
        | jq -r --arg c "$cidr" \
          '[.[] | select(.direction == "inbound" and .protocol == "tcp" and (.remote.cidr_block // "") == $c)] | length')
      if [[ "${existing:-0}" -gt 0 ]]; then
        log_ok "SSH from ${ip} is already allowed."
        return
      fi

      ibmcloud is security-group-rule-add "$sg_id" inbound tcp \
        --port-min 22 --port-max 22 \
        --remote "$cidr" \
        --output JSON -q > /dev/null \
        || die "Failed to add rule for ${cidr}"
      log_ok "SSH access allowed from ${ip}"
      ;;

    deny)
      if [[ "${1:-}" == "--all" ]]; then
        log_info "Removing all SSH access rules..."
        local rules; rules=$(ic security-group-rules "$sg_id")
        local removed=0
        while IFS= read -r rule_id; do
          ibmcloud is security-group-rule-delete "$sg_id" "$rule_id" --force -q \
            || log_warn "Could not remove rule ${rule_id} (continuing)"
          (( ++removed ))
        done < <(echo "$rules" | jq -r '.[] | select(.direction == "inbound") | .id')
        log_ok "Removed ${removed} rule(s) — VM is now locked."
      else
        local ip="${1:-}"
        [[ -n "$ip" ]] || { log_info "Detecting public IP..."; ip=$(my_ip); }
        local cidr; cidr=$(ip_to_cidr "$ip")
        local rule_id
        rule_id=$(ic security-group-rules "$sg_id" \
          | jq -r --arg c "$cidr" \
            '.[] | select(.direction == "inbound" and .protocol == "tcp" and (.remote.cidr_block // "") == $c) | .id')
        [[ -n "$rule_id" ]] || die "No SSH rule found for ${cidr}"
        ibmcloud is security-group-rule-delete "$sg_id" "$rule_id" --force -q \
          || die "Failed to remove rule for ${cidr}"
        log_ok "SSH access removed for ${ip}"
      fi
      ;;

    *)
      die "Unknown subcommand: 'ibmvm access ${subcmd}'  (use: allow, deny, list)"
      ;;
  esac
}

# ── Commands ──────────────────────────────────────────────────────────────────
cmd_create() {
  local name="$1"; shift
  local vm="${VM_PREFIX}${name}"
  local profile="$PROFILE"
  local image_arg=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --profile) profile="$2"; shift 2 ;;
      --image)   image_arg="$2"; shift 2 ;;
      *) die "Unknown option for create: $1" ;;
    esac
  done

  local status; status=$(get_instance_status "$vm")
  [[ "$status" == "not_found" ]] || die "Instance '${vm}' already exists (status: ${status})"

  local zone; zone=$(get_zone)

  local _img_input="${image_arg:-${IMAGE:-}}"
  [[ -n "$_img_input" ]] || die "No image configured. Run: ibmvm setup or pass --image <name|id>"
  local _img_resolved; _img_resolved=$(resolve_image "$_img_input")
  local image_id; image_id=$(printf '%s' "$_img_resolved" | cut -f1)
  local image_name; image_name=$(printf '%s' "$_img_resolved" | cut -f2)
  log_info "Image: ${image_name}"

  local subnet_id key_id
  subnet_id=$(ic_id subnets "$SUBNET_NAME")
  [[ -n "$subnet_id" ]] || die "Subnet '${SUBNET_NAME}' not found. Run: ibmvm setup"
  key_id=$(ic_id keys "$KEY_NAME")
  [[ -n "$key_id" ]] || die "SSH key '${KEY_NAME}' not found. Run: ibmvm setup"

  log_info "Creating instance '${vm}' (profile: ${profile}, zone: ${zone})..."
  ibmcloud is instance-create "$vm" "$VPC_NAME" "$zone" "$profile" "$subnet_id" \
    --image "$image_id" \
    --keys "$key_id" \
    --resource-group-name "$RG_NAME" \
    --output JSON -q > /dev/null \
    || die "Failed to create instance '${vm}'"

  wait_for_status "$vm" "running"

  local access_sg; access_sg=$(access_sg_id)
  if [[ -n "$access_sg" ]]; then
    local nic_id; nic_id=$(get_primary_nic_id "$vm")
    if [[ -n "$nic_id" ]]; then
      ibmcloud is security-group-target-add "$access_sg" "$nic_id" \
        --output JSON -q > /dev/null \
        || log_warn "Could not attach access security group (SSH access rules may not apply)"
    fi
  fi

  log_info "Assigning floating IP..."
  local ip; ip=$(assign_floating_ip "$vm")
  log_ok "  floating IP: ${ip}"

  echo ""
  echo -e "  ${C_BOLD}IP:${C_RST}    ${ip}"
  echo -e "  ${C_BOLD}SSH:${C_RST}   ssh -i ${SSH_KEY_FILE} ${SSH_USER}@${ip}"
  echo ""
  log_info "SSH will be ready shortly — connecting automatically via: ibmvm ssh ${name}"
}

cmd_start() {
  local name="$1"; shift
  local vm="${VM_PREFIX}${name}"
  local opts=("$@")

  local status; status=$(get_instance_status "$vm")
  case "$status" in
    running)
      log_ok "Instance '${name}' is already running."
      ;;
    stopped|shutoff)
      log_info "Starting instance '${name}'..."
      ibmcloud is instance-start "$vm" --output JSON -q > /dev/null \
        || die "Failed to start instance '${name}'"
      wait_for_status "$vm" "running"
      log_ok "Instance '${name}' is running."
      ;;
    not_found)
      confirm "Instance '${name}' does not exist. Create it?" \
        || { log_info "Aborted."; exit 0; }
      cmd_create "$name" "${opts[@]+"${opts[@]}"}"
      ;;
    *)
      die "Instance '${name}' is in state '${status}' — cannot start."
      ;;
  esac
}

cmd_stop() {
  local name="$1"
  local vm="${VM_PREFIX}${name}"
  local status; status=$(get_instance_status "$vm")
  case "$status" in
    stopped|shutoff)
      log_ok "Instance '${name}' is already stopped."
      ;;
    running|starting)
      log_info "Stopping instance '${name}'..."
      ibmcloud is instance-stop "$vm" --force --output JSON -q > /dev/null \
        || die "Failed to stop instance '${name}'"
      wait_for_status "$vm" "stopped"
      log_ok "Instance '${name}' stopped."
      ;;
    not_found)
      die "Instance '${name}' not found."
      ;;
    *)
      die "Instance '${name}' is in state '${status}' — cannot stop."
      ;;
  esac
}

_rm_instance() {
  local name="$1"   # full prefixed name e.g. ibmvm-myvm
  local short="${name#"$VM_PREFIX"}"
  local fip_name="${name}-fip"

  local fip; fip=$(fip_id "$fip_name")
  if [[ -n "$fip" ]]; then
    log_info "Releasing floating IP '${fip_name}'..."
    ibmcloud is floating-ip-release "$fip" --force -q \
      || log_warn "Could not release floating IP (continuing)"
  fi
  log_info "Removing instance '${short}'..."
  ibmcloud is instance-delete "$name" --force --output JSON -q > /dev/null \
    || die "Failed to remove instance '${name}'"
  log_ok "Instance '${short}' removed."
}

cmd_rm() {
  local name="${1:-}"; shift || true

  # ── rm --all ──────────────────────────────────────────────────────────────
  if [[ "$name" == "--all" ]]; then
    local out; out=$(list_ibmvm_instances)
    local count; count=$(echo "$out" | jq 'length')

    if [[ "$count" -eq 0 ]]; then
      log_info "No instances in resource group '${RG_NAME}'."
    else
      confirm "Remove all ${count} instance(s) in resource group '${RG_NAME}'?" \
        || { log_info "Aborted."; exit 0; }
      while IFS= read -r inst; do
        _rm_instance "$(echo "$inst" | jq -r '.name')"
      done < <(echo "$out" | jq -c '.[]')
    fi

    # Offer to tear down ibmvm-managed infrastructure
    if [[ -n "${SETUP_DONE_REGION:-}" ]]; then
      echo ""
      log_info "ibmvm infrastructure in '${RG_NAME}':"
      printf "    VPC:    %s\n" "$VPC_NAME"
      printf "    Subnet: %s\n" "$SUBNET_NAME"
      printf "    Key:    %s\n" "$KEY_NAME"
      printf "    RG:     %s\n" "$RG_NAME"
      echo ""
      confirm "Also remove all ibmvm infrastructure (VPC, subnet, key, resource group)?" \
        || { log_ok "Done."; exit 0; }

      local key_id subnet_id vpc_id access_sg
      key_id=$(ic_id keys "$KEY_NAME")
      subnet_id=$(ic_id subnets "$SUBNET_NAME")
      vpc_id=$(ic_id vpcs "$VPC_NAME")
      access_sg=$(access_sg_id)

      if [[ -n "$access_sg" ]]; then
        log_info "Removing access security group '${ACCESS_SG_NAME}'..."
        ibmcloud is security-group-delete "$access_sg" --force -q \
          || log_warn "Could not remove access security group (continuing)"
      fi

      log_info "Removing SSH key '${KEY_NAME}'..."
      if [[ -n "$key_id" ]]; then
        ibmcloud is key-delete "$key_id" --force -q \
          || log_warn "Could not remove key (continuing)"
      else
        log_warn "Key '${KEY_NAME}' not found, skipping"
      fi

      log_info "Removing subnet '${SUBNET_NAME}'..."
      if [[ -n "$subnet_id" ]]; then
        ibmcloud is subnet-delete "$subnet_id" --force -q \
          || log_warn "Could not remove subnet (continuing)"
      else
        log_warn "Subnet '${SUBNET_NAME}' not found, skipping"
      fi

      log_info "Removing VPC '${VPC_NAME}'..."
      if [[ -n "$vpc_id" ]]; then
        ibmcloud is vpc-delete "$vpc_id" --force -q \
          || log_warn "Could not remove VPC (continuing)"
      else
        log_warn "VPC '${VPC_NAME}' not found, skipping"
      fi

      log_info "Removing resource group '${RG_NAME}'..."
      ibmcloud resource group-delete "$RG_NAME" -f \
        || log_warn "Could not remove resource group (continuing)"

      SETUP_DONE_REGION=""
      save_config
      log_ok "All ibmvm infrastructure removed."

      echo ""
      if confirm "Also remove local ibmvm config directory (${IBMVM_DIR})?"; then
        rm -rf "$IBMVM_DIR"
        log_ok "${IBMVM_DIR} removed."
      fi
    fi
    return
  fi

  # ── rm <name> ─────────────────────────────────────────────────────────────
  local vm="${VM_PREFIX}${name}"
  local status; status=$(get_instance_status "$vm")
  [[ "$status" != "not_found" ]] || die "Instance '${name}' not found."
  _rm_instance "$vm"
}

cmd_ssh() {
  local target="$1"; shift
  local extra_args=()

  local ssh_user short_name
  if [[ "$target" == *@* ]]; then
    ssh_user="${target%%@*}"
    short_name="${target##*@}"
  else
    ssh_user="$SSH_USER"
    short_name="$target"
  fi
  local name="${VM_PREFIX}${short_name}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --)  shift; extra_args+=("$@"); break ;;
      *)   extra_args+=("$1"); shift ;;
    esac
  done

  local status; status=$(get_instance_status "$name")
  case "$status" in
    not_found)
      confirm "Instance '${short_name}' does not exist. Create it?" || { log_info "Aborted."; exit 0; }
      cmd_create "$short_name"
      ;;
    stopped|shutoff)
      confirm "Instance '${short_name}' is stopped. Start it?" || exit 0
      cmd_start "$short_name"
      ;;
    running)
      ;;
    *)
      die "Instance '${short_name}' is in state '${status}' — cannot SSH."
      ;;
  esac

  local ip; ip=$(get_floating_ip "$name")
  [[ -n "$ip" ]] || die "No floating IP found for '${short_name}'."

  # Check access SG and offer to allow current IP if not already permitted
  local sg_id; sg_id=$(access_sg_id)
  if [[ -n "$sg_id" ]]; then
    local pub_ip
    pub_ip=$(my_ip 2>/dev/null || true)
    if [[ -n "$pub_ip" ]]; then
      local cidr; cidr=$(ip_to_cidr "$pub_ip")
      local existing
      existing=$(ic security-group-rules "$sg_id" \
        | jq -r --arg c "$cidr" \
          '[.[] | select(.direction == "inbound" and .protocol == "tcp" and (.remote.cidr_block // "") == $c)] | length')
      if [[ "${existing:-0}" -eq 0 ]]; then
        confirm_yes "Your IP (${pub_ip}) is not in the allow list. Add it?" || { log_info "Aborted."; exit 0; }
        ibmcloud is security-group-rule-add "$sg_id" inbound tcp \
          --port-min 22 --port-max 22 \
          --remote "$cidr" \
          --output JSON -q > /dev/null \
          || die "Failed to add SSH rule for ${pub_ip}"
        log_ok "SSH access allowed from ${pub_ip}"
      fi
    fi
  fi

  log_info "Connecting to ${ssh_user}@${ip}..."
  local tries=0 max=20
  while (( tries < max )); do
    [[ "$tries" -gt 0 ]] && printf "\r  Waiting for SSH... (%ds)" $(( tries * 5 ))
    local rc=0
    ssh -i "$SSH_KEY_FILE" \
      -o StrictHostKeyChecking=no \
      -o UserKnownHostsFile=/dev/null \
      -o LogLevel=ERROR \
      -o ConnectTimeout=5 \
      "${extra_args[@]+"${extra_args[@]}"}" \
      "${ssh_user}@${ip}" && rc=0 || rc=$?
    [[ "$rc" -ne 255 ]] && { printf "\r\033[K"; exit "$rc"; }
    (( ++tries < max )) && sleep 5
  done
  die "SSH not available after $(( max * 5 ))s — try: ssh -i ${SSH_KEY_FILE} ${ssh_user}@${ip}"
}

cmd_list() {
  local out; out=$(list_ibmvm_instances)
  local count; count=$(echo "$out" | jq 'length')

  if [[ "$count" -eq 0 ]]; then
    log_info "No instances found in resource group '${RG_NAME}'."
    return
  fi

  printf "${C_BOLD}%-22s %-12s %-16s %-14s${C_RST}\n" "NAME" "STATUS" "FLOATING IP" "PROFILE"
  printf "${C_DIM}%-22s %-12s %-16s %-14s${C_RST}\n" "----" "------" "-----------" "-------"

  while IFS= read -r inst; do
    local iname_full iname istatus iprofile fip
    iname_full=$(echo "$inst" | jq -r '.name')
    iname=$(echo "$inst" | jq -r --arg p "$VM_PREFIX" '.name | ltrimstr($p)')
    istatus=$(echo "$inst" | jq -r '.status')
    iprofile=$(echo "$inst" | jq -r '.profile.name')
    fip=$(get_floating_ip "$iname_full")
    [[ -n "$fip" ]] || fip="-"
    printf "%-22s %-12s %-16s %-14s\n" "$iname" "$istatus" "$fip" "$iprofile"
  done < <(echo "$out" | jq -c '.[]')
}

cmd_status() {
  local name="${VM_PREFIX}${1}"
  local data; data=$(get_instance_json "$name")
  [[ -n "$data" ]] || die "Instance '${1}' not found."

  local status profile zone mem vcpus
  status=$(echo "$data" | jq -r '.status')
  profile=$(echo "$data" | jq -r '.profile.name')
  zone=$(echo "$data" | jq -r '.zone.name')
  mem=$(echo "$data" | jq -r '.memory // "-"')
  vcpus=$(echo "$data" | jq -r '.vcpu.count // "-"')

  local fip; fip=$(get_floating_ip "$name")
  [[ -n "$fip" ]] || fip="-"

  echo ""
  printf "  ${C_BOLD}%-14s${C_RST} %s\n" "Name:"        "${1}"
  printf "  ${C_BOLD}%-14s${C_RST} %s\n" "Status:"      "$status"
  printf "  ${C_BOLD}%-14s${C_RST} %s\n" "Profile:"     "$profile"
  printf "  ${C_BOLD}%-14s${C_RST} %s vCPU  %s GB RAM\n" "Compute:" "$vcpus" "$mem"
  printf "  ${C_BOLD}%-14s${C_RST} %s\n" "Zone:"        "$zone"
  printf "  ${C_BOLD}%-14s${C_RST} %s\n" "Floating IP:" "$fip"
  if [[ "$fip" != "-" ]]; then
    printf "  ${C_BOLD}%-14s${C_RST} ssh -i %s %s@%s\n" "SSH:" "$SSH_KEY_FILE" "$SSH_USER" "$fip"
  fi
  echo ""
}

# ── Help ──────────────────────────────────────────────────────────────────────
usage() {
  cat <<EOF

${C_BOLD}ibmvm${C_RST} — Simple IBM Cloud VPC VM manager

${C_BOLD}USAGE${C_RST}
  ibmvm [global-opts] <command> [name] [opts]

${C_BOLD}COMMANDS${C_RST}
  setup               Verify / create all prerequisites (VPC, subnet, SSH key…)
  create  <name>      Create and start a new VM
  start   <name>      Start a VM (prompts to create if it doesn't exist)
  stop    <name>      Stop a running VM
  rm      <name>      Remove a VM and its floating IP
  rm      --all       Remove all VMs in the resource group (optionally tears down infra)
  ssh     <name>      SSH into a VM (starts it first if stopped, auto-allows your IP)
  list                List all VMs in the resource group
  status  <name>      Show VM details

${C_BOLD}ACCESS${C_RST}  (manage which IPs can SSH to your VMs)
  access list         Show currently allowed IPs
  access allow [ip]   Allow SSH from an IP (defaults to your current public IP)
  access deny  [ip]   Remove SSH access for an IP (defaults to your current public IP)
  access deny --all   Remove all SSH access rules (lock down)

${C_BOLD}OPTIONS${C_RST}
  --profile <name>    VM profile  (create only, default from setup)
  --image   <name>    Image name or pattern  (create only, overrides the image chosen during setup)

${C_BOLD}EXAMPLES${C_RST}
  ibmvm setup                          # first-time interactive setup
  ibmvm start myvm                     # create + start ibmvm-myvm (or just start if stopped)
  ibmvm ssh myvm                       # SSH in (starts if stopped)
  ibmvm ssh ubuntu@myvm                # SSH as a different user
  ibmvm ssh myvm -- -L 8080:localhost:8080  # SSH with port-forward
  ibmvm stop myvm
  ibmvm rm myvm                        # removes ibmvm-myvm
  ibmvm rm --all                       # removes all ibmvm-* instances
  ibmvm list

${C_BOLD}CONFIG${C_RST}  ~/.ibmvm/config.<account-id>  (managed by ibmvm setup)

EOF
}

# ── Entry point ───────────────────────────────────────────────────────────────
main() {
  load_config

  # Parse global flags that appear before the command word only
  while [[ $# -gt 0 ]] && [[ "$1" == --* ]]; do
    case "$1" in
      --help|-h)      usage; exit 0 ;;
      --profile)      PROFILE="$2"; shift 2 ;;
      --profile=*)    PROFILE="${1#*=}"; shift ;;
      *)              die "Unknown flag: $1" ;;
    esac
  done

  local cmd="${1:-help}"; shift || true

  case "$cmd" in
    help)   usage; exit 0 ;;
    setup)  cmd_setup; exit 0 ;;
  esac

  ensure_prerequisites

  # Persist any flag overrides for next run
  save_config

  case "$cmd" in
    create)  [[ $# -ge 1 ]] || die "Usage: ibmvm create <name> [--profile P]"
             cmd_create "$@" ;;
    start)   [[ $# -ge 1 ]] || die "Usage: ibmvm start <name>"
             cmd_start "$@" ;;
    stop)    [[ $# -ge 1 ]] || die "Usage: ibmvm stop <name>"
             cmd_stop "$1" ;;
    rm)      [[ $# -ge 1 ]] || die "Usage: ibmvm rm <name|--all>"
             cmd_rm "$1" ;;
    ssh)     [[ $# -ge 1 ]] || die "Usage: ibmvm ssh <name> [--user U] [-- ssh-args]"
             cmd_ssh "$@" ;;
    list)    [[ $# -eq 0 ]] || die "ibmvm list takes no arguments"
             cmd_list ;;
    status)  [[ $# -ge 1 ]] || die "Usage: ibmvm status <name>"
             cmd_status "$1" ;;
    access)  cmd_access "$@" ;;
    *)       die "Unknown command: '${cmd}'  (run 'ibmvm help' for usage)" ;;
  esac
}

main "$@"
